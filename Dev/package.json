{
  "name": "alexquant-userscript",
  "version": "1.5.0",
  "description": "Schwab Holdings Live Table",
  "main": "src/AlexQuant.ts",
  "scripts": {
    "build": "cross-env NODE_ENV=production webpack --mode production --config webpack.config.js",
    "dev": "cross-env NODE_ENV=development webpack --watch --mode development --config webpack.config.js",
    "lint": "npm run lint:eslint && npm run lint:checks",
    "lint:eslint": "eslint \"./**/*.{js,mjs,cjs,ts,tsx}\" --max-warnings=0",
    "lint:checks": "npm run lint:time && npm run lint:hygiene && npm run lint:boundaries",
    "lint:time": "node scripts/check-time-rules.mjs",
    "lint:time:baseline": "node scripts/check-time-rules.mjs --write-baseline",
    "lint:hygiene": "node scripts/check-hygiene-rules.mjs",
    "lint:boundaries": "node scripts/check-ui-boundaries.mjs",
    "lint:boundaries:baseline": "node scripts/check-ui-boundaries.mjs --write-baseline",
    "test": "jest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md,yml,yaml}\""
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "babel-loader": "^9.1.3",
    "cross-env": "^10.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "webpack": "^5.101.3",
    "webpack-cli": "^5.1.4",
    "ws": "^8.19.0"
  },
  "private": true,
  "sideEffects": false,
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
